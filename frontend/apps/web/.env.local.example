# ใช้ /api ผ่าน Next.js proxy (default) — ไม่ต้องเปลี่ยนตอนเข้าจาก IP ใน WiFi
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api

# Production บน server 96 ผ่าน nginx /production (ตั้งก่อน pnpm build):
# NEXT_PUBLIC_BASE_PATH=/production

# เข้าจากเครื่องอื่นใน WiFi: http://<IP-เครื่อง-host>:3000 เท่านั้น (ไม่ต้องเปิด port 3001)
