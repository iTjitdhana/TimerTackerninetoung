# Database (MySQL — ใส่แบบแยกตัวแปรใน backend/.env)
DB_HOST=192.168.0.96
DB_USER=jitdhana
DB_PASSWORD=your_password_here
DB_NAME=MNF_database411
DB_PORT=3306

# Optional: second MySQL database for read-only production steps (process_steps table)
# If omitted, the app reads process_steps from DB_NAME as a fallback source.
# STEPS_DB_HOST=192.168.0.96
# STEPS_DB_USER=jitdhana
# STEPS_DB_PASSWORD=your_password_here
# STEPS_DB_NAME=manufacturing_system
# STEPS_DB_PORT=3306

# Optional: external DB for process_templates (read-only)
# TEMPLATES_DB_HOST=192.168.0.96
# TEMPLATES_DB_USER=jitdhana
# TEMPLATES_DB_PASSWORD=your_password_here
# TEMPLATES_DB_NAME=manufacturing_system
# TEMPLATES_DB_PORT=3306

# ใช้ prisma db pull + db:generate เท่านั้น — ไม่รัน migrate กับ DB เดิม
# DATABASE_URL จะถูกสร้างอัตโนมัติจาก DB_* โดย scripts/load-env.cjs

# Backend
PORT=3001
# NODE_ENV=production จะบังคับให้ JWT_SECRET เป็นค่าที่แข็งแรง (>= 16 ตัวอักษร)
# และห้ามเป็นค่า default เช่น dev-secret / change-me — มิฉะนั้น backend จะไม่ start
JWT_SECRET="change-me-in-production"
# เปิด PIN เดโม (1234/5678/9999) เฉพาะตอน dev เท่านั้น — production จะถูกปิดเสมอ
ALLOW_DEMO_PINS=false
# แยก authorization ของ TimeTracker จาก role ร่วมใน DB (true = ใช้ timetracker_user_roles)
TIMETRACKER_OWN_AUTH=false
# role_id คงที่สำหรับ users ใหม่ (ระบบอื่น) เมื่อ TIMETRACKER_OWN_AUTH=true
TIMETRACKER_DEFAULT_ORG_ROLE_ID=5
WORKPLAN_PROVIDER=db
WORKPLAN_API_URL=""
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://192.168.0.96:8080"
# Standard work day length for daily-wage labor cost (minutes). Default: 495 = 8h 15m
LABOR_STANDARD_WORK_MINUTES=495

# Onhand Cost Price API (optional — ถ้าไม่ตั้งจะใช้ materials.price ตามเดิม)
ONHAND_COST_PRICE_API_URL=http://192.168.0.96/onhand_system/api/cost_price.php
ONHAND_COST_PRICE_API_TOKEN=

# BOM source: db (อ่าน fg_bom) หรือ http (ดึงจาก onhand bom_standard.php)
BOM_PROVIDER=db
BOM_STANDARD_API_URL=http://192.168.0.96/onhand_system/api/bom_standard.php
BOM_STANDARD_API_TOKEN=

# Frontend (frontend/apps/web/.env.local)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
