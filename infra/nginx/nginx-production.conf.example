# TimeTracker — nginx snippet สำหรับ deploy ใต้ /production บน port 8080
# ใส่ใน server { listen 8080; } ที่มี /portal/ อยู่แล้ว — อย่าแก้ config portal
#
# ก่อนใช้:
#   1. รัน NestJS ที่ 127.0.0.1:3001
#   2. รัน Next.js ที่ 127.0.0.1:3000 (build ด้วย NEXT_PUBLIC_BASE_PATH=/production)
#   3. nginx -t && nginx -s reload

# API + SSE — ต้องอยู่ก่อน location /production/
location /production/api/ {
    proxy_pass http://127.0.0.1:3001/api/;
    proxy_http_version 1.1;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # SSE real-time stream — ห้าม buffer
    proxy_buffering          off;
    proxy_cache              off;
    proxy_read_timeout       3600s;
    proxy_set_header         Connection '';
    chunked_transfer_encoding off;
}

location /production/ {
    proxy_pass http://127.0.0.1:3000/production/;
    proxy_http_version 1.1;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        "upgrade";
}

location = /production {
    return 302 /production/login;
}
